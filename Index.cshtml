@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: Arial, Helvetica, sans-serif;
        background-color: white;
        color: #222;
    }

    .container {
        max-width: 1200px;
        margin: 18px auto;
        padding: 0 16px;
    }

    /* MENU */
    .menu {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 18px 0;
        border-bottom: 1px solid #ddd;
        font-size: 18px;
        overflow-x: auto;
    }

    .menu a {
        text-decoration: none;
        color: black;
        white-space: nowrap;
    }

    .menu a:hover {
        color: #b00000;
    }

    /* NEWS TOP */
    .top-news {
        display: flex;
        margin-top: 25px;
        gap: 25px;
        border-bottom: 1px solid #ddd;
        padding-bottom: 25px;
        align-items: flex-start;
    }

    .top-news img {
        width: 620px;
        height: 400px;
        object-fit: cover;
        flex-shrink: 0;
        border-radius: 2px;
    }

    .top-content {
        flex: 1;
    }

    .top-content h1 {
        font-size: 48px;
        line-height: 1.2;
        margin-bottom: 14px;
        font-family: Georgia, "Times New Roman", Times, serif;
    }

    .top-content p {
        font-size: 20px;
        line-height: 1.6;
        color: #555;
        margin-bottom: 18px;
    }

    .time {
        color: gray;
        font-size: 16px;
    }

    /* BOTTOM NEWS */
    .bottom-news {
        display: flex;
        gap: 25px;
        margin-top: 30px;
        align-items: flex-start;
    }

    .news-card {
        flex: 1;
        background: #fff;
    }

    .news-card img {
        width: 100%;
        height: 240px;
        object-fit: cover;
        margin-top: 12px;
        border-radius: 2px;
    }

    .news-card h2 {
        font-size: 22px;
        line-height: 1.3;
        font-family: Georgia, "Times New Roman", Times, serif;
    }

    .side-box {
        width: 320px;
        background: #f3f3f3;
        padding: 20px;
        border-radius: 2px;
        flex-shrink: 0;
    }

    .side-box h3 {
        color: #8b0033;
        margin-bottom: 12px;
        font-size: 20px;
    }

    .side-box h2 {
        font-size: 24px;
        margin-bottom: 12px;
        line-height: 1.4;
        font-family: Georgia, "Times New Roman", Times, serif;
    }

    .side-box p {
        color: #666;
        font-size: 16px;
        line-height: 1.5;
    }

    /* RESPONSIVE */
    @@media (max-width: 992px) {

        .top-news img {
            width: 48%;
            height: auto;
        }

        .bottom-news {
            gap: 16px;
        }

        .side-box {
            width: 280px;
        }
    }

    @@media (max-width: 768px) {

        .container {
            width: 95%;
        }

        .top-news {
            flex-direction: column;
        }

        .top-news img {
            width: 100%;
            height: auto;
        }

        .bottom-news {
            flex-direction: column;
        }

        .side-box {
            width: 100%;
        }

        .menu {
            gap: 12px;
            font-size: 16px;
        }

        .top-content h1 {
            font-size: 28px;
        }

        .top-content p {
            font-size: 16px;
        }

        .news-card img {
            height: 200px;
        }
    }
</style>

<div class="container">

    <!-- MENU -->
    <nav class="menu" role="navigation" aria-label="Main navigation">
        <a href="#">🏠</a>
        <a href="#">VnE-GO</a>
        <a href="#">Thời sự</a>
        <a href="#">Thế giới</a>
        <a href="#">Kinh doanh</a>
        <a href="#">Khoa học công nghệ</a>
        <a href="#">Góc nhìn</a>
        <a href="#">Spotlight</a>
        <a href="#">Bất động sản</a>    
        <a href="#">Sức khỏe</a>
        <a href="#">Giải trí</a>
    </nav>

    <!-- TOP NEWS -->
    <section class="top-news" aria-labelledby="top-headline">

        <img src="@(Url.Content("~/images/anh1.png"))" alt="Ảnh chính">

        <div class="top-content">
            <h1 id="top-headline">Ưu tiên tái định cư trước khi triển khai Trục cảnh quan sông Hồng</h1>

            <p>
                Hà Nội sẽ ưu tiên xây dựng các khu tái định cư trước khi triển khai
                Trục Đại lộ cảnh quan sông Hồng - dự án hơn 11.400 ha,
                liên quan khoảng 247.000 dân ven sông, thực hiện giai đoạn 2026-2038.
            </p>

            <div class="time">1h trước</div>
        </div>

    </section>

    <!-- BOTTOM -->
    <section class="bottom-news" aria-label="Top stories">

        <article class="news-card" aria-labelledby="card1">
            <h2 id="card1">Hà Nội giải phóng mặt bằng cho hơn 1.400 dự án</h2>

            <img src="@(Url.Content("~/images/anh2.png"))" alt="Ảnh 2">
        </article>

        <article class="news-card" aria-labelledby="card2">
            <h2 id="card2">TP HCM siết kiểm soát người nhập cảnh phòng Ebola</h2>

            <img src="@(Url.Content("~/images/anh3.png"))" alt="Ảnh 3">
        </article>

        <aside class="side-box" aria-labelledby="opinion">
            <h3>Góc nhìn</h3>

            <h2 id="opinion">Bóc lột trên YouTube</h2>

            <p>
                Khi cỗ máy Content ID của YouTube bị trục lợi,
                nhiều nghệ sĩ bị ảnh hưởng doanh thu và bản quyền.
            </p>
        </aside>

    </section>

</div>